layout {
    border {
        active-color   "#99f161"
        inactive-color "#8a9480"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#99f161"
        inactive-color "#8a9480"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#99f16180"
    }
}

